{
  "name": "bellezapos-desktop",
  "version": "1.1.0",
  "description": "BellezaPOS Desktop empaquetado como aplicacion de escritorio con Electron.",
  "main": "electron/main.js",
  "author": "BellezaPOS Desktop",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "start:web-api": "node support-api/src/server.js",
    "db:diagnose": "node scripts/diagnose-desktop.js",
    "db:tenant:provision": "node scripts/provision-tenant-db.js",
    "db:tenant:validate": "node scripts/validate-tenant-schema.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "mongodb": "^7.1.1",
    "mysql2": "^3.11.3"
  },
  "build": {
    "appId": "com.bellezapos.desktop",
    "productName": "BellezaPOS Desktop",
    "icon": "icon.ico",
    "files": [
      "**/*",
      "assets/**/*",
      "support-api/**/*",
      "!db.config.json",
      "!farmapos/**",
      "!plantilla-online/**",
      "!*.gs",
      "!README.md",
      "!INVENTARIO-SETUP.md"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist-new"
    },
    "win": {
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}

